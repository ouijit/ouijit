---
import Site from '../layouts/Site.astro';
import WorkspaceScene from '../components/demo/WorkspaceScene.tsx';

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Ouijit',
  alternateName: 'Ouijit (Integrated Divination Environment)',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS 13+, Linux (x64)',
  description:
    'Ouijit is a customizable task and terminal session manager that integrates with agent CLIs and TUIs via lifecycle hooks, scripts, and a session-aware CLI. It offers basic comforts for agentic development like live agent status with notifications, automatic worktree management for parallel workstreams, and VM sandboxing for untrusted code.',
  url: 'https://ouijit.com',
  downloadUrl: 'https://github.com/ouijit/ouijit/releases/latest',
  softwareHelp: 'https://ouijit.com/docs/',
  license: 'https://github.com/ouijit/ouijit/blob/main/LICENSE',
  isAccessibleForFree: true,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Ouijit',
    url: 'https://ouijit.com',
  },
  screenshot: [
    'https://ouijit.com/assets/screenshots/kanban.png',
    'https://ouijit.com/assets/screenshots/terminal-stack.png',
    'https://ouijit.com/assets/screenshots/canvas.png',
    'https://ouijit.com/assets/screenshots/settings.png',
  ],
  featureList: [
    'Per-task git worktrees with Copy-on-Write cloning',
    'Kanban board with lifecycle hooks',
    'Integrated terminal sessions with card stack UI',
    'Live status indicators for Claude Code, Codex, and Pi',
    'VM sandbox via Lima for isolated agent terminals',
    'Session-aware ouijit CLI for driving the app from a shell',
  ],
  sameAs: ['https://github.com/ouijit/ouijit'],
};
---
<Site>
  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />
  <section class="hero">
    <h1>Integrated Divination Environment</h1>
    <div class="download-buttons">
      <a
        href="https://github.com/ouijit/ouijit/releases/latest/download/ouijit-darwin-arm64.dmg"
        class="btn btn-primary">Download for macOS (Apple Silicon)</a>
      <a
        href="https://github.com/ouijit/ouijit/releases/latest/download/ouijit-darwin-x64.dmg"
        class="btn btn-secondary">macOS (Intel)</a>
      <a href="https://github.com/ouijit/ouijit/releases/latest/download/ouijit-linux-x64.zip" class="btn btn-secondary"
        >Linux</a>
    </div>
    <p class="hero-fine-print">Free and open source. No account, no sign-in, no telemetry.</p>
    <div class="mobile-cta">
      <div class="mobile-cta-note" role="note">View on desktop to download</div>
    </div>
  </section>

  <section class="hero-scene">
    <WorkspaceScene client:visible />
  </section>

  <section class="home-pitch">
    <p>
      Ouijit is a customizable task and terminal session manager that integrates with agent CLIs and TUIs via
      lifecycle hooks, scripts, and a session-aware CLI. It offers basic comforts for agentic development like
      live agent status with notifications, automatic worktree management for parallel workstreams, and VM
      sandboxing for untrusted code.
    </p>
    <a class="home-pitch-link" href="/docs/">Read the docs <span aria-hidden="true">→</span></a>
  </section>

  <section class="home-agents">
    <h2>Supported harnesses</h2>
    <ul class="home-agents-grid">
      <li>
        <a class="glass-bevel" href="https://claude.com/claude-code">
          <img src="/assets/agents/claude-code.svg" alt="" width="40" height="40" />
          <span class="home-agents-name">Claude Code</span>
          <span class="home-agents-domain">claude.com/claude-code</span>
        </a>
      </li>
      <li>
        <a class="glass-bevel" href="https://github.com/openai/codex">
          <img src="/assets/agents/codex.svg" alt="" width="40" height="40" />
          <span class="home-agents-name">Codex</span>
          <span class="home-agents-domain">github.com/openai/codex</span>
        </a>
      </li>
      <li>
        <a class="glass-bevel" href="https://pi.dev">
          <img src="/assets/agents/pi.svg" alt="" width="40" height="40" />
          <span class="home-agents-name">Pi</span>
          <span class="home-agents-domain">pi.dev</span>
        </a>
      </li>
    </ul>
    <p class="home-agents-footnote">
      To request support for another harness,
      <a href="https://github.com/ouijit/ouijit/issues/new">open an issue</a>.
    </p>
  </section>
</Site>
