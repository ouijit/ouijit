---
import Site from '../layouts/Site.astro';
import WorkspaceScene from '../components/demo/WorkspaceScene.tsx';
---
<Site title="Ouijit · Features" description="A board for the work in flight, a stack of terminals per task, and a fresh git worktree under each one.">
  <section class="features-hero">
    <div class="features-hero-inner">
      <span class="eyebrow">Features</span>
      <h1>One workspace. A fleet of agents.</h1>
      <p class="subtitle">
        The board tracks the work. The terminals run it. Both stay open at once.
      </p>
    </div>
    <div class="features-scene">
      <WorkspaceScene client:visible />
    </div>
  </section>
</Site>
