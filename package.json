{
  "name": "ouijit",
  "productName": "ouijit",
  "version": "1.0.26",
  "description": "Discover and manage your local development projects",
  "main": ".vite/build/main.js",
  "bin": {
    "ouijit": "./dist-cli/ouijit.js"
  },
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:linux": "./scripts/build-linux.sh",
    "publish": "electron-forge publish",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && eslint src/ && prettier --check src/",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "pretest": "npm rebuild better-sqlite3 --silent",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:e2e": "npx electron-rebuild -o better-sqlite3 --force 2>/dev/null || true",
    "test:e2e": "node e2e/build.mjs && npx playwright test --config e2e/playwright.config.ts",
    "pretest:e2e:ci": "npx electron-rebuild -o better-sqlite3 --force 2>/dev/null || true",
    "test:e2e:ci": "node e2e/build.mjs && xvfb-run npx playwright test --config e2e/playwright.config.ts",
    "build:cli": "node scripts/build-cli.mjs",
    "test:full": "vitest run && node e2e/build.mjs && npx playwright test --config e2e/playwright.config.ts",
    "postinstall": "./scripts/download-lima.sh && chmod +x node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null || true",
    "db:reset": "./scripts/db-reset.sh"
  },
  "keywords": [],
  "author": "pbjer",
  "license": "AGPL-3.0-or-later",
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-deb": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "@electron-forge/plugin-fuses": "^7.10.2",
    "@electron-forge/plugin-vite": "^7.10.2",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@electron/notarize": "^3.1.1",
    "@floating-ui/react": "^0.27.19",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "electron": "39.2.7",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "react-hotkeys-hook": "^5.2.4",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.4.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@phosphor-icons/core": "^2.1.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "dompurify": "^3.3.3",
    "electron-log": "^5.4.3",
    "electron-squirrel-startup": "^1.0.1",
    "fix-path": "^5.0.0",
    "hotkeys-js": "^4.0.0",
    "koffi": "^2.15.1",
    "launch-editor": "^2.13.2",
    "marked": "^17.0.5",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shiki": "^4.0.2",
    "update-electron-app": "^3.1.2",
    "yaml": "^2.8.3",
    "zustand": "^5.0.11"
  },
  "overrides": {
    "tar": "^7.5.7",
    "tmp": "^0.2.5"
  }
}
